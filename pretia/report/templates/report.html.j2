<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Pretia Report — {{ workflow_name }}</title>
<style>
*,*::before,*::after{box-sizing:border-box}
body{
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  color:#1a202c;background:#fff;margin:0;padding:0;line-height:1.6;
}
.container{max-width:900px;margin:0 auto;padding:1.5rem 1rem}
h1{font-size:1.75rem;margin:0 0 .25rem}
h2{font-size:1.25rem;margin:1.75rem 0 .75rem;padding-bottom:.4rem;border-bottom:2px solid #e2e8f0}
h3{font-size:1rem;margin:.25rem 0}
.subtitle{color:#718096;font-size:.875rem;margin:0 0 1.5rem}

/* Score hero */
.score-hero{text-align:center;padding:1.5rem 0}
.zone-badge{
  display:inline-block;padding:.25rem .75rem;border-radius:9999px;
  color:#fff;font-weight:600;font-size:.875rem;margin-top:.5rem;
}
.scope-note{color:#a0aec0;font-size:.8rem;font-style:italic;margin-top:.35rem}

/* Stat cards row */
.stat-cards{display:flex;gap:1rem;flex-wrap:wrap;margin:1rem 0}
.stat-card{
  flex:1;min-width:120px;background:#f7fafc;border:1px solid #e2e8f0;
  border-radius:6px;padding:.75rem 1rem;text-align:center;
}
.stat-card .label{font-size:.75rem;color:#718096;text-transform:uppercase;letter-spacing:.5px}
.stat-card .value{font-size:1.25rem;font-weight:700;margin-top:.15rem}

/* Tables */
table{width:100%;border-collapse:collapse;margin:.5rem 0 1rem}
th,td{padding:.5rem .75rem;text-align:right;border-bottom:1px solid #e2e8f0;font-size:.875rem}
th{font-weight:600;color:#4a5568;background:#f7fafc}
th:first-child,td:first-child{text-align:left}
tr.row-emphasis td{font-weight:700;background:#fffff0}
tr.cvar-row td{border-top:2px solid #e2e8f0;color:#718096;font-style:italic}

/* Confidence badge */
.confidence-label{font-size:.8rem;font-weight:600;padding:.15rem .5rem;border-radius:4px}
.confidence-label--high{background:#c6f6d5;color:#276749}
.confidence-label--moderate{background:#fefcbf;color:#975a16}
.confidence-label--low{background:#fed7d7;color:#9b2c2c}
.confidence-label--very_low{background:#feb2b2;color:#742a2a}

/* Patterns */
.pattern-item{padding:.5rem 0;border-bottom:1px solid #edf2f7}
.pattern-item:last-child{border-bottom:none}
.pattern-type{font-weight:600}
.pattern-step{color:#718096}
.severity-warning{color:#d69e2e}
.severity-danger{color:#e53e3e}
.no-data{color:#38a169;padding:.75rem 0}

/* Recommendation cards */
.rec-card{
  border-left:4px solid #e2e8f0;padding:1rem;margin:.75rem 0;
  background:#f8fafc;border-radius:0 6px 6px 0;
}
.rec-card--model_swap{border-left-color:#319795}
.rec-card--architecture{border-left-color:#3182ce}
.rec-card--workflow{border-left-color:#805ad5}
.type-badge{
  display:inline-block;font-size:.7rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.5px;padding:.15rem .4rem;border-radius:3px;color:#fff;
}
.type-badge--model_swap{background:#319795}
.type-badge--architecture{background:#3182ce}
.type-badge--workflow{background:#805ad5}
.top-label{
  display:inline-block;font-size:.7rem;font-weight:700;text-transform:uppercase;
  background:#ecc94b;color:#744210;padding:.1rem .4rem;border-radius:3px;margin-left:.4rem;
}
.rec-desc{color:#4a5568;margin:.4rem 0}
.rec-meta{font-size:.85rem;color:#718096}
.rec-savings{font-weight:700}
.rec-savings--model_swap{color:#319795}
.rec-savings--architecture{color:#3182ce}
.rec-savings--workflow{color:#805ad5}

/* Waterfall */
.waterfall-wrap{overflow-x:auto}

/* Raw data toggle */
details{margin-top:1.5rem}
details summary{cursor:pointer;font-weight:600;padding:.5rem 0;color:#4a5568}
details pre{
  background:#f7fafc;border:1px solid #e2e8f0;border-radius:6px;
  padding:1rem;overflow-x:auto;font-size:.75rem;line-height:1.4;
  max-height:400px;overflow-y:auto;
}

/* Footer */
footer{
  margin-top:2rem;padding-top:1rem;border-top:1px solid #e2e8f0;
  text-align:center;color:#a0aec0;font-size:.8rem;
}
footer a{color:#718096}
.meta{margin-top:.25rem}

/* Responsive */
@media(max-width:640px){
  .container{padding:.75rem .5rem}
  .stat-cards{flex-direction:column}
  table{font-size:.8rem}
  th,td{padding:.35rem .5rem}
}
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <h1>Pretia Report</h1>
  <p class="subtitle">
    Workflow: <strong>{{ workflow_name }}</strong>
    &nbsp;|&nbsp; {{ total_runs }} run{{ "s" if total_runs != 1 else "" }}
    {%- if total_steps %}, {{ total_steps }} step{{ "s" if total_steps != 1 else "" }}{% endif %}
    &nbsp;|&nbsp; {{ profiled_at_display }}
  </p>

  <!-- Score Ring Hero -->
  {% if score %}
  <div class="score-hero">
    {{ score_ring_svg | safe }}
    <div>
      <span class="zone-badge" style="background:{{ score.zone_color }}">
        {{ score.zone_label }}
      </span>
    </div>
    {% if score.score <= 70 and score.scope_note %}
    <div class="scope-note">{{ score.scope_note }}</div>
    {% endif %}
  </div>

  <!-- Score summary cards -->
  <div class="stat-cards">
    <div class="stat-card">
      <div class="label">Recoverable Savings</div>
      <div class="value">{{ score.total_savings | format_cost }}</div>
    </div>
    <div class="stat-card">
      <div class="label">Waste</div>
      <div class="value">{{ "%.0f" | format(score.waste_pct * 100) }}%</div>
    </div>
    <div class="stat-card">
      <div class="label">Recommendations</div>
      <div class="value">{{ score.recommendation_count }}</div>
    </div>
  </div>
  {% endif %}

  <!-- Cost Per Run -->
  {% if cost_per_run %}
  <h2>Cost Per Run</h2>
  <div class="stat-cards">
    <div class="stat-card">
      <div class="label">Median (p50)</div>
      <div class="value">{{ cost_per_run.p50 | format_cost }}</div>
    </div>
    <div class="stat-card">
      <div class="label">Mean</div>
      <div class="value">{{ cost_per_run.mean | format_cost }}</div>
    </div>
    <div class="stat-card">
      <div class="label">p95</div>
      <div class="value">{{ cost_per_run.p95 | format_cost }}</div>
    </div>
    <div class="stat-card">
      <div class="label">p99</div>
      <div class="value">{{ cost_per_run.p99 | format_cost }}</div>
    </div>
  </div>
  {% endif %}

  <!-- Projection Table -->
  {% if projection_rows %}
  <h2>Monthly Cost Projection</h2>
  {% if confidence %}
  <p>
    Method: <strong>{{ projection_method }}</strong>
    &nbsp;|&nbsp; Confidence:
    <span class="confidence-label confidence-label--{{ confidence.tier | lower }}">
      {{ confidence.tier }}
    </span>
  </p>
  {% endif %}
  <div style="overflow-x:auto">
  <table>
    <thead>
      <tr>
        <th></th>
        {% for vol in traffic_volumes %}
        <th>{{ "{:,}".format(vol) }}/day</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for pct in ["p50", "p75", "p90", "p95", "p99"] %}
      <tr{% if pct == "p50" %} class="row-emphasis"{% endif %}>
        <td>{{ pct }}</td>
        {% for vol in traffic_volumes %}
        <td>{{ projection_rows[vol][pct] | format_cost }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
      {% if has_cvar %}
      <tr class="cvar-row">
        <td>CVaR (p95)</td>
        {% for vol in traffic_volumes %}
        <td>{{ cvar_values[vol] | format_cost }}</td>
        {% endfor %}
      </tr>
      {% endif %}
    </tbody>
  </table>
  </div>
  {% if has_cvar %}
  <p style="font-size:.8rem;color:#718096;font-style:italic">
    CVaR (p95): When monthly cost exceeds p95, expect this amount on average.
  </p>
  {% endif %}
  {% endif %}

  <!-- Cost Waterfall Chart -->
  {% if steps %}
  <h2>Cost Breakdown by Step</h2>
  <div class="waterfall-wrap">
    {{ waterfall_svg | safe }}
  </div>
  {% endif %}

  <!-- Patterns -->
  <h2>Detected Patterns</h2>
  {% if has_patterns %}
  {% for p in patterns %}
  <div class="pattern-item">
    <span class="severity-{{ p.severity | default('warning') }}">
      {% if p.severity == "danger" %}&#x1f534;{% else %}&#x1f7e1;{% endif %}
    </span>
    <span class="pattern-type">{{ p.pattern_type | default("unknown") | replace("_", " ") | title }}</span>
    <span class="pattern-step">&mdash; Step &lsquo;{{ p.step_name }}&rsquo;</span>
    <div style="margin-left:1.5rem;color:#4a5568">{{ p.description }}</div>
  </div>
  {% endfor %}
  {% else %}
  <p class="no-data">No non-linear cost patterns detected. Linear projection is reliable.</p>
  {% endif %}

  <!-- Recommendations -->
  <h2>Recommendations</h2>
  {% if has_recommendations %}
  {% for rec in recommendations %}
  <div class="rec-card rec-card--{{ rec.type }}">
    <span class="type-badge type-badge--{{ rec.type }}">{{ rec.type | replace("_", " ") }}</span>
    {% if loop.first %}<span class="top-label">Top Recommendation</span>{% endif %}
    <h3>{{ rec.title }}</h3>
    <p class="rec-desc">{{ rec.description }}</p>
    <div class="rec-meta">
      Saves <span class="rec-savings rec-savings--{{ rec.type }}">{{ rec.monthly_savings | format_cost }}</span>/month
      &nbsp;|&nbsp; Confidence:
      <span class="confidence-label confidence-label--{{ rec.confidence | lower }}">{{ rec.confidence }}</span>
    </div>
  </div>
  {% endfor %}
  {% else %}
  <p class="no-data">No recommendations &mdash; your workflow is already well optimized.</p>
  {% endif %}

  <!-- Raw Data Toggle -->
  <details>
    <summary>Raw profile data (JSON)</summary>
    <pre><code>{{ raw_json }}</code></pre>
  </details>

  <!-- Footer -->
  <footer>
    <p>Profiled with <a href="https://github.com/pretia-ai/pretia">Pretia</a></p>
    <p class="meta">
      {{ total_runs }} run{{ "s" if total_runs != 1 else "" }}
      {%- if profiling_cost %} | Cost: {{ profiling_cost | format_cost }}{% endif %}
      {%- if framework %} | Framework: {{ framework }}{% endif %}
      | {{ profiled_at_display }}
      {%- if pretia_version %} | v{{ pretia_version }}{% endif %}
    </p>
  </footer>

</div>
</body>
</html>
